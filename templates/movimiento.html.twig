{% extends 'base/base.html.twig' %}

{% block content %}
    <div class="content">
        {{ form_start(form) }}
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title"> Movimientos</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table">
                                <thead class=" text-primary">
                                    <th>Id</th>
                                    <th>Fecha</th>
                                    <th>Numero</th>
                                </thead>
                                <tbody>
                                {% for arMovimiento in arMovimientos %}
                                <tr>
                                    <td>{{ arMovimiento.codigoMovimientoPk }}</td>
                                    <td>{{ arMovimiento.fecha | date('Y-m-d') }}</td>
                                    <td>{{ arMovimiento.numero }}</td>
                                    <td align="center"><input type="checkbox" name="ChkSeleccionar[]"
                                                              value="{{ arMovimiento.codigoMovimientoPk }}"/></td>
                                </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <div class="row">
                        <div class="col-sm-9 col-sm-offset-3">
                            <div style="float: right; margin-right: 5px !important;" class="btn-group" role="group"
                                 aria-label="...">
                                {{ form_widget(form.btnTransferir) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}